<Page x:Class="CosmeticStoreManagement.Views.Staff.StaffCustomerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="StaffCustomerPage"
      Background="#FFF1F6F1">
    <Page.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#FFFDFEFD"/>
            <Setter Property="BorderBrush" Value="#FFD6E3D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD2DFD4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TableHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFE7F1E8"/>
            <Setter Property="Foreground" Value="#FF2F4E35"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderBrush" Value="#FFE7F1E8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="TableCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#FF243B29"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFDCEBDE"/>
                    <Setter Property="Foreground" Value="#FF243B29"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TableRowStyle" TargetType="DataGridRow">
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#FFF8FBF8"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FFFDFEFD"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFEDF6EE"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFDCEBDE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="1.1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Customer List"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="#FF23422D"/>
                        <TextBlock Grid.Row="1"
                                   Text="View customers, search by customer name, and choose one record to update."
                                   Margin="0,6,0,16"
                                   FontSize="15"
                                   Foreground="#FF68806D"/>

                        <Border Grid.Row="2"
                                Background="#FFF5F9F5"
                                BorderBrush="#FFD6E3D8"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="10">
                            <DataGrid ItemsSource="{Binding CustomerView}"
                                      SelectedItem="{Binding selecteditem, Mode=OneWayToSource}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      RowHeaderWidth="0"
                                      GridLinesVisibility="None"
                                      HeadersVisibility="Column"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      ColumnHeaderStyle="{StaticResource TableHeaderStyle}"
                                      CellStyle="{StaticResource TableCellStyle}"
                                      RowStyle="{StaticResource TableRowStyle}"
                                      AlternationCount="2"
                                      HorizontalGridLinesBrush="#FFE2ECE3"
                                      VerticalGridLinesBrush="#FFE2ECE3">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding CustomerId}" Width="70"/>
                                    <DataGridTextColumn Header="Customer Name" Binding="{Binding CustomerName}" Width="*"/>
                                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="130"/>
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="170"/>
                                    <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="220"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource CardBorder}"
                        Padding="16"
                        Background="#FFF4FAF5">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Customer Form"
                                       FontSize="38"
                                       FontWeight="Bold"
                                       Foreground="#FF23422D"/>
                            <TextBlock Text="Use Add Customer to create a record or select one customer from the list and use Update Customer."
                                       Margin="0,6,0,14"
                                       Foreground="#FF68806D"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Customer ID" Margin="0,8,0,4" FontWeight="Bold" Foreground="#FF34513B"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding textboxitem.CustomerId}"
                                     IsReadOnly="True"/>

                            <TextBlock Text="Customer Name" Margin="0,10,0,4" FontWeight="Bold" Foreground="#FF34513B"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding textboxitem.CustomerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Phone" Margin="0,10,0,4" FontWeight="Bold" Foreground="#FF34513B"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding textboxitem.Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Email" Margin="0,10,0,4" FontWeight="Bold" Foreground="#FF34513B"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding textboxitem.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Address" Margin="0,10,0,4" FontWeight="Bold" Foreground="#FF34513B"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding textboxitem.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <UniformGrid Rows="1" Columns="3" Margin="0,16,0,0">
                                <Button Content="Add Customer"
                                        Margin="0,0,8,0"
                                        Background="#FF3E6B48"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding AddCommand}"/>
                                <Button Content="Update Customer"
                                        Margin="0,0,8,0"
                                        Background="#FF6B8E51"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding UpdateCommand}"/>
                                <Button Content="Clear Form"
                                        Background="#FF7A8F80"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding ClearCommand}"/>
                            </UniformGrid>

                            <TextBlock Text="Search" Margin="0,16,0,4" FontWeight="Bold" Foreground="#FF34513B"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         Text="{Binding searchtext, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Content="Search"
                                        Background="#FF5F8267"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding SearchCommand}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,10,0,0"
                Padding="10"
                CornerRadius="12"
                Background="#FFFBFFFB"
                BorderBrush="#FFDCE8DE"
                BorderThickness="1">
            <TextBlock Text="{Binding statusmessage}"
                       Foreground="#FF31573A"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Page>
