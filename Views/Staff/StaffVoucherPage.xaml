<Page x:Class="CosmeticStoreManagement.Views.Staff.StaffVoucherPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="StaffVoucherPage"
      Background="#FFF1F6F1"
      d:DesignHeight="650"
      d:DesignWidth="1100">
    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF244330"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF6F8273"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="170"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD9E4DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinWidth" Value="260"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD9E4DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF3E6B48"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF4A7C5E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFE8F2EA"/>
            <Setter Property="Foreground" Value="#FF3E6B48"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="False"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="58"/>
            <Setter Property="AlternatingRowBackground" Value="#FFF8FBF9"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF5F7462"/>
            <Setter Property="Background" Value="#FFF4F8F5"/>
            <Setter Property="BorderBrush" Value="#00000000"/>
            <Setter Property="Padding" Value="10,12"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Margin="0,0,0,18">
            <Border.Effect>
                <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Voucher List"
                           Style="{StaticResource SectionTitleStyle}"/>
                <TextBlock Text="Review all vouchers, check which ones are usable now, and inspect discount details for customers at the counter."
                           Margin="0,6,0,18"
                           Foreground="#FF6B7F70"
                           TextWrapping="Wrap"/>

                <WrapPanel>
                    <StackPanel Margin="0,0,14,12">
                        <TextBlock Text="Status" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding StatusOptions}"
                                  SelectedItem="{Binding SelectedStatus}"
                                  Style="{StaticResource FilterComboBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,14,12">
                        <TextBlock Text="Search" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchTextBoxStyle}"/>
                    </StackPanel>

                    <Button Content="Clear filters"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Margin="0,0,10,12"
                            Command="{Binding ClearFiltersCommand}"/>

                    <Button Content="Refresh"
                            Style="{StaticResource PrimaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,12"
                            Command="{Binding RefreshCommand}"/>
                </WrapPanel>

                <WrapPanel Margin="0,4,0,0">
                    <Border Background="#FFE9F3EB" CornerRadius="12" Padding="12,6" Margin="0,0,10,0">
                        <TextBlock Text="{Binding TotalVouchers, StringFormat='Total: {0}'}"
                                   Foreground="#FF3E6B48"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#FFEAF4ED" CornerRadius="12" Padding="12,6" Margin="0,0,10,0">
                        <TextBlock Text="{Binding AvailableVouchers, StringFormat='Available: {0}'}"
                                   Foreground="#FF3E6B48"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#FFFDF0DD" CornerRadius="12" Padding="12,6" Margin="0,0,10,0">
                        <TextBlock Text="{Binding UpcomingVouchers, StringFormat='Upcoming: {0}'}"
                                   Foreground="#FFB97925"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#FFFBE9E7" CornerRadius="12" Padding="12,6">
                        <TextBlock Text="{Binding ExpiredVouchers, StringFormat='Expired: {0}'}"
                                   Foreground="#FFD55342"
                                   FontWeight="SemiBold"/>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.45*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <Border.Effect>
                    <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="2"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="20,20,20,12">
                        <StackPanel>
                            <TextBlock Text="Available Voucher Records"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Select one voucher to inspect its status and validity dates."
                                       Margin="0,4,0,0"
                                       Foreground="#FF6B7F70"/>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding VouchersView}"
                              SelectedItem="{Binding SelectedVoucher}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code"
                                                Binding="{Binding VoucherCode}"
                                                Width="1.2*"/>
                            <DataGridTextColumn Header="Type"
                                                Binding="{Binding DiscountTypeDisplay}"
                                                Width="110"/>
                            <DataGridTextColumn Header="Discount"
                                                Binding="{Binding DiscountDisplay}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Start"
                                                Binding="{Binding StartDate, StringFormat='{}{0:dd/MM/yyyy}'}"
                                                Width="110"/>
                            <DataGridTextColumn Header="End"
                                                Binding="{Binding EndDate, StringFormat='{}{0:dd/MM/yyyy}'}"
                                                Width="110"/>
                            <DataGridTextColumn Header="Qty left"
                                                Binding="{Binding QuantityDisplay}"
                                                Width="90"/>
                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding StatusText}"
                                                Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="18"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Border.Effect>
                    <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="2"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Voucher Details"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="{Binding SelectedVoucherSummary}"
                                   Margin="0,6,0,14"
                                   Foreground="#FF6B7F70"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="#FFF8FBF9"
                                    CornerRadius="14"
                                    Padding="28"
                                    Visibility="{Binding HasSelectedVoucher, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="No voucher selected"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#FF3E6B48"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Choose a voucher from the table to view its discount information."
                                               Margin="0,8,0,0"
                                               Foreground="#FF6B7F70"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Visibility="{Binding HasSelectedVoucher, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Border Background="#FFF4F8F5"
                                        CornerRadius="14"
                                        Padding="18"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedVoucher.VoucherCode}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#FF244330"/>
                                        <TextBlock Text="{Binding SelectedVoucher.StatusText, StringFormat='Current status: {0}'}"
                                                   Margin="0,6,0,0"
                                                   Foreground="#FF6B7F70"/>
                                        <TextBlock Text="{Binding SelectedVoucher.ValidityDisplay, StringFormat='Validity: {0}'}"
                                                   Margin="0,6,0,0"
                                                   Foreground="#FF6B7F70"/>
                                        <TextBlock Text="{Binding SelectedVoucher.QuantityDisplay, StringFormat='Remaining: {0}'}"
                                                   Margin="0,6,0,0"
                                                   Foreground="#FF6B7F70"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#FFF9FCFA"
                                        CornerRadius="14"
                                        BorderBrush="#FFE1ECE3"
                                        BorderThickness="1"
                                        Padding="18"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Discount Type"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="{Binding SelectedVoucher.DiscountTypeDisplay}"
                                                       FontWeight="Bold"
                                                       Foreground="#FF244330"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Discount Value"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="{Binding SelectedVoucher.DiscountDisplay}"
                                                       FontWeight="Bold"
                                                       Foreground="#FF3E6B48"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Background="#FFF5F8F5"
                                        CornerRadius="14"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Usage Note"
                                                   Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBlock Text="Staff can use this page to verify whether a voucher is active, upcoming, expired, and what discount it provides before applying it for a customer."
                                                   Foreground="#FF627365"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
