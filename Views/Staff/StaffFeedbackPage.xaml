<Page x:Class="CosmeticStoreManagement.Views.Staff.StaffFeedbackPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="StaffFeedbackPage"
      Background="#FFF1F6F1"
      d:DesignHeight="650"
      d:DesignWidth="1100">
    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF244330"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF6F8273"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="170"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD9E4DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinWidth" Value="260"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD9E4DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF3E6B48"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF4A7C5E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFE8F2EA"/>
            <Setter Property="Foreground" Value="#FF3E6B48"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="False"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="58"/>
            <Setter Property="AlternatingRowBackground" Value="#FFF8FBF9"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF5F7462"/>
            <Setter Property="Background" Value="#FFF4F8F5"/>
            <Setter Property="BorderBrush" Value="#00000000"/>
            <Setter Property="Padding" Value="10,12"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Margin="0,0,0,18">
            <Border.Effect>
                <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Customer Feedback"
                           Style="{StaticResource SectionTitleStyle}"/>
                <TextBlock Text="Choose a completed order, then submit the customer's rating and comment from this dedicated feedback tab."
                           Margin="0,6,0,18"
                           Foreground="#FF6B7F70"
                           TextWrapping="Wrap"/>

                <WrapPanel>
                    <StackPanel Margin="0,0,14,12">
                        <TextBlock Text="Search completed orders" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchTextBoxStyle}"/>
                    </StackPanel>

                    <Button Content="Refresh"
                            Style="{StaticResource PrimaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,12"
                            Command="{Binding RefreshCommand}"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.45*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <Border.Effect>
                    <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="2"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="20,20,20,12">
                        <TextBlock Text="Completed Orders"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Only completed orders created by the current staff account are listed here."
                                   Margin="0,4,0,0"
                                   Foreground="#FF6B7F70"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding OrdersView}"
                              SelectedItem="{Binding SelectedOrder}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Order"
                                                Binding="{Binding OrderId, StringFormat='#{0}'}"
                                                Width="80"/>
                            <DataGridTextColumn Header="Date"
                                                Binding="{Binding OrderDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                                Width="145"/>
                            <DataGridTextColumn Header="Customer"
                                                Binding="{Binding CustomerName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Phone"
                                                Binding="{Binding CustomerPhone}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Final Amount"
                                                Binding="{Binding FinalAmount, StringFormat='{}{0:N0} VND'}"
                                                Width="130"/>
                            <DataGridTextColumn Header="Rating"
                                                Binding="{Binding RatingDisplay}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Customer Comment"
                                                Binding="{Binding Comment}"
                                                Width="1.2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="18"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Border.Effect>
                    <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="2"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Feedback Form"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Select an order from the left to edit or submit customer feedback."
                                   Margin="0,6,0,14"
                                   Foreground="#FF6B7F70"
                                   TextWrapping="Wrap"/>

                        <Border Background="#FFF8FBF9"
                                CornerRadius="14"
                                Padding="28"
                                Visibility="{Binding HasSelectedOrder, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="No order selected"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#FF3E6B48"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Choose a completed order from the table to add customer feedback."
                                           Margin="0,8,0,0"
                                           Foreground="#FF6B7F70"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Visibility="{Binding HasSelectedOrder, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border Background="#FFF4F8F5"
                                    CornerRadius="14"
                                    Padding="16"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedOrder.OrderId, StringFormat='Order #{0}'}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#FF244330"/>
                                    <TextBlock Text="{Binding SelectedOrder.CustomerName}"
                                               Margin="0,8,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="#FF3E6B48"/>
                                    <TextBlock Text="{Binding SelectedOrder.CustomerPhone}"
                                               Margin="0,4,0,0"
                                               Foreground="#FF6B7F70"/>
                                    <TextBlock Text="{Binding SelectedOrder.FinalAmount, StringFormat='Total: {0:N0} VND'}"
                                               Margin="0,4,0,0"
                                               Foreground="#FF6B7F70"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Rating"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding RatingOptions}"
                                      SelectedItem="{Binding SelectedRating}"
                                      Style="{StaticResource FilterComboBoxStyle}"/>

                            <TextBlock Text="Comment"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Margin="0,14,0,0"/>
                            <TextBox Text="{Binding FeedbackComment, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="140"
                                     Padding="12"
                                     Background="White"
                                     BorderBrush="#FFD9E4DB"
                                     BorderThickness="1"/>

                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="Save Feedback"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,0,10,0"
                                        Command="{Binding SaveFeedbackCommand}"/>
                                <Button Content="Reset"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding ResetCommand}"/>
                            </WrapPanel>

                            <Border Background="#FFFFFBF1"
                                    BorderBrush="#FFE7DDB7"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10"
                                    Margin="0,14,0,0">
                                <TextBlock Text="{Binding StatusMessage}"
                                           Foreground="#FF856018"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
