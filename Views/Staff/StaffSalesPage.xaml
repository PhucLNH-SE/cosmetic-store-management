<Page x:Class="CosmeticStoreManagement.Views.Staff.StaffSalesPage"
      x:Name="SalesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="StaffSalesPage"
      Background="#FFF1F6F1"
      d:DesignHeight="650"
      d:DesignWidth="1100">
    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF244330"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF6F8273"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="170"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD9E4DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinWidth" Value="250"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD9E4DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CustomerResultItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="itemBorder"
                                Background="#FFF8FBF9"
                                BorderBrush="#FFE1ECE3"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10,8">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#FFF0F6F1"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#FFE7F2E9"/>
                                <Setter TargetName="itemBorder" Property="BorderBrush" Value="#FFBFD6C5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF3E6B48"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF4A7C5E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFE8F2EA"/>
            <Setter Property="Foreground" Value="#FF3E6B48"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFBE9E7"/>
            <Setter Property="Foreground" Value="#FFD55342"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style x:Key="QtyButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="False"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="58"/>
            <Setter Property="AlternatingRowBackground" Value="#FFF8FBF9"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF5F7462"/>
            <Setter Property="Background" Value="#FFF4F8F5"/>
            <Setter Property="BorderBrush" Value="#00000000"/>
            <Setter Property="Padding" Value="10,12"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Margin="0,0,0,12"
                Padding="18">
            <Border.Effect>
                <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Counter Sales"
                           Style="{StaticResource SectionTitleStyle}"/>
                <TextBlock Text="Choose the buyer, add product variants to the cart, update quantities, and checkout directly from the staff panel."
                           Margin="0,4,0,12"
                           Foreground="#FF6B7F70"
                           TextWrapping="Wrap"/>

                <WrapPanel>
                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="Brand" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Brands}"
                                  SelectedItem="{Binding SelectedBrand}"
                                  DisplayMemberPath="BrandName"
                                  Style="{StaticResource FilterComboBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="Category" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  DisplayMemberPath="CategoryName"
                                  Style="{StaticResource FilterComboBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="Sort" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding SortOptions}"
                                  SelectedItem="{Binding SelectedSort}"
                                  Style="{StaticResource FilterComboBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="Search" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchTextBoxStyle}"/>
                    </StackPanel>

                    <Button Content="Clear filters"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Height="36"
                            Margin="0,0,0,8"
                            Click="ClearFilters_Click"/>
                </WrapPanel>

                <Border Background="#FFF7FAF7"
                        CornerRadius="12"
                        Padding="12"
                        BorderBrush="#FFDCE8DE"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.35*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Buyer"
                                        Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="Type the customer name, then click a result."
                                       Margin="0,0,0,6"
                                       Foreground="#FF708172"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                            <Grid>
                                <TextBox x:Name="BuyerSearchTextBox"
                                         Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SearchTextBoxStyle}"
                                         MinWidth="0"/>

                                <Popup PlacementTarget="{Binding ElementName=BuyerSearchTextBox}"
                                       Placement="Bottom"
                                       VerticalOffset="6"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade"
                                       StaysOpen="False"
                                       IsOpen="{Binding ShowCustomerSuggestions}">
                                    <Border Width="{Binding ActualWidth, ElementName=BuyerSearchTextBox}"
                                            Background="White"
                                            BorderBrush="#FFD9E4DB"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="8">
                                        <Grid>
                                            <ListBox ItemsSource="{Binding CustomerOptionsView}"
                                                     SelectedItem="{Binding SelectedCustomer}"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     MaxHeight="220"
                                                     ItemContainerStyle="{StaticResource CustomerResultItemStyle}"
                                                     Visibility="{Binding HasCustomerResults, Converter={StaticResource BoolToVisibilityConverter}}"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding CustomerName}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#FF244330"/>
                                                            <TextBlock Text="{Binding Phone, StringFormat='Phone: {0}'}"
                                                                       Margin="0,4,0,0"
                                                                       FontSize="12"
                                                                       Foreground="#FF708172"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>

                                            <TextBlock Text="No customer matches this search."
                                                       Padding="8"
                                                       Foreground="#FF8B6A2E"
                                                       Visibility="{Binding ShowCustomerNoResults, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </Grid>
                                    </Border>
                                </Popup>
                            </Grid>
                        </StackPanel>

                        <Border Grid.Column="2"
                                Background="#FFEAF4EC"
                                CornerRadius="10"
                                Padding="10">
                            <Grid>
                                <Grid Visibility="{Binding HasSelectedCustomer, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="Selected Customer"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Foreground="#FF305239"/>
                                        <TextBlock Text="{Binding SelectedCustomerName}"
                                                   Margin="0,4,0,0"
                                                   FontWeight="Bold"
                                                   Foreground="#FF244330"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SelectedCustomerPhone}"
                                                   Margin="0,3,0,0"
                                                   Foreground="#FF5F7462"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Visibility="{Binding HasSelectedCustomer, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <TextBlock Text="Please choose a customer before checkout."
                                               VerticalAlignment="Center"
                                               Foreground="#FF8B6A2E"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.55*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <Border.Effect>
                    <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="2"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="20,20,20,12">
                        <StackPanel>
                            <TextBlock Text="Available Products"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Choose a variant and add it to the current cart."
                                       Margin="0,4,0,0"
                                       Foreground="#FF6B7F70"/>
                        </StackPanel>

                        <Border DockPanel.Dock="Right"
                                Background="#FFE9F3EB"
                                CornerRadius="12"
                                Padding="12,6"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding ProductVariants.Count, StringFormat='{}{0} variant(s)'}"
                                       Foreground="#FF3E6B48"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ProductVariantsView}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="64">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="42"
                                                Height="42"
                                                CornerRadius="10"
                                                Background="#FFF5F7F5"
                                                Margin="4">
                                            <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                                   Stretch="UniformToFill">
                                                <Image.Clip>
                                                    <RectangleGeometry Rect="0,0,42,42" RadiusX="10" RadiusY="10"/>
                                                </Image.Clip>
                                            </Image>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Product"
                                                Binding="{Binding Product.ProductName}"
                                                Width="2*"/>
                            <DataGridTextColumn Header="Brand"
                                                Binding="{Binding Product.Brand.BrandName}"
                                                Width="1.2*"/>
                            <DataGridTextColumn Header="Category"
                                                Binding="{Binding Product.Category.CategoryName}"
                                                Width="1.2*"/>
                            <DataGridTextColumn Header="Variant"
                                                Binding="{Binding Volume}"
                                                Width="90"/>
                            <DataGridTextColumn Header="Price"
                                                Binding="{Binding Price, StringFormat='{}{0:N0} VND'}"
                                                Width="110"/>
                            <DataGridTextColumn Header="Stock"
                                                Binding="{Binding StockQuantity}"
                                                Width="70"/>

                            <DataGridTemplateColumn Header="Action" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Add"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Padding="12,7"
                                                Command="{Binding DataContext.AddToCartCommand, ElementName=SalesPage}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="18"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Border.Effect>
                    <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="2"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Current Cart"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Review selected items, update quantities, and checkout."
                                   Margin="0,6,0,8"
                                   Foreground="#FF6B7F70"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="#FFF8FBF9"
                                    CornerRadius="14"
                                    Padding="28"
                                    Visibility="{Binding HasCartItems, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Cart is empty"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#FF3E6B48"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Select products from the table to start a counter order."
                                               Margin="0,8,0,0"
                                               Foreground="#FF6B7F70"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding CartItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFF9FCFA"
                                                CornerRadius="14"
                                                BorderBrush="#FFE1ECE3"
                                                BorderThickness="1"
                                                Padding="14"
                                                Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="58"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Width="46"
                                                        Height="46"
                                                        CornerRadius="10"
                                                        Background="#FFF0F4F0">
                                                    <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                                           Stretch="UniformToFill">
                                                        <Image.Clip>
                                                            <RectangleGeometry Rect="0,0,46,46" RadiusX="10" RadiusY="10"/>
                                                        </Image.Clip>
                                                    </Image>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="8,0,12,0">
                                                    <TextBlock Text="{Binding ProductName}"
                                                               FontWeight="Bold"
                                                               Foreground="#FF244330"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Volume, StringFormat='Variant: {0}'}"
                                                               Margin="0,4,0,0"
                                                               Foreground="#FF6B7F70"/>
                                                    <TextBlock Text="{Binding UnitPrice, StringFormat='{}{0:N0} VND each'}"
                                                               Margin="0,4,0,0"
                                                               Foreground="#FF3E6B48"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding AvailableStock, StringFormat='Available stock: {0}'}"
                                                               Margin="0,4,0,0"
                                                               Foreground="#FF8A988C"
                                                               FontSize="12"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                    <Button Content="Remove"
                                                            Style="{StaticResource DangerButtonStyle}"
                                                            Command="{Binding DataContext.RemoveFromCartCommand, ElementName=SalesPage}"
                                                            CommandParameter="{Binding}"
                                                            HorizontalAlignment="Right"/>

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,14,0,8"
                                                                HorizontalAlignment="Right">
                                                        <Button Content="-"
                                                                Style="{StaticResource QtyButtonStyle}"
                                                                Command="{Binding DataContext.DecreaseQuantityCommand, ElementName=SalesPage}"
                                                                CommandParameter="{Binding}"/>
                                                        <Border Background="#FFF1F6F1"
                                                                CornerRadius="8"
                                                                Width="44"
                                                                Height="28"
                                                                Margin="8,0">
                                                            <TextBlock Text="{Binding Quantity}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="Bold"
                                                                       Foreground="#FF244330"/>
                                                        </Border>
                                                        <Button Content="+"
                                                                Style="{StaticResource QtyButtonStyle}"
                                                                Command="{Binding DataContext.IncreaseQuantityCommand, ElementName=SalesPage}"
                                                                CommandParameter="{Binding}"/>
                                                    </StackPanel>

                                                    <TextBlock Text="{Binding LineTotal, StringFormat='{}{0:N0} VND'}"
                                                               HorizontalAlignment="Right"
                                                               FontWeight="Bold"
                                                               Foreground="#FF244330"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Margin="0,8,0,0"
                            Padding="12"
                            CornerRadius="14"
                            Background="#FFF5F8F5">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="Voucher"
                                           Foreground="#FF627365"
                                           FontWeight="SemiBold"/>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="Optional"
                                           Foreground="#FF8A988C"
                                           FontSize="11"/>
                            </DockPanel>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="84"/>
                                    <ColumnDefinition Width="84"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Style="{StaticResource SearchTextBoxStyle}"
                                         MinWidth="0"
                                         Height="32"
                                         Text="{Binding VoucherCodeInput, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="1"
                                        Margin="6,0,0,0"
                                        Content="Apply"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Padding="8,5"
                                        Command="{Binding ApplyVoucherCommand}"/>
                                <Button Grid.Column="2"
                                        Margin="6,0,0,0"
                                        Content="Clear"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="8,5"
                                        Command="{Binding ClearVoucherCommand}"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="{Binding AppliedVoucherCode, StringFormat='Voucher: {0}'}"
                                           Foreground="#FF627365"
                                           Margin="0,0,8,4"/>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding VoucherDiscountDisplay, StringFormat='Discount: {0}'}"
                                           HorizontalAlignment="Right"
                                           FontWeight="SemiBold"
                                           Foreground="#FF3E6B48"
                                           Margin="8,0,0,4"/>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Text="{Binding TotalQuantity, StringFormat='Items: {0}'}"
                                           Foreground="#FF627365"
                                           Margin="0,0,8,4"/>
                                <TextBlock Grid.Row="1"
                                           Grid.Column="1"
                                           Text="{Binding CartTotal, StringFormat='Total: {0:N0} VND'}"
                                           HorizontalAlignment="Right"
                                           FontWeight="SemiBold"
                                           Foreground="#FF627365"
                                           Margin="8,0,0,4"/>

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Text="Final total"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#FF244330"/>
                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Text="{Binding FinalCartTotalDisplay}"
                                           HorizontalAlignment="Right"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="#FF3E6B48"/>
                            </Grid>

                            <Button Content="Checkout"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding CheckoutCommand}"
                                    IsEnabled="{Binding CanCheckout}"
                                    Height="34"
                                    Padding="12,6"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
