<Page x:Class="CosmeticStoreManagement.Views.ManageProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ManageProductPage">
    <Grid Background="#FFF9F6F2">
        <Border Background="#FFF3E8DE"
                CornerRadius="24"
                Padding="28"
                Margin="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Manage Product"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#FF4A2E1E"
                           Margin="0,0,0,20"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*" />
                        <ColumnDefinition Width="4*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="10" Margin="0,0,15,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Search:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF6F5547" Margin="0,0,10,0"/>
                                <TextBox Text="{Binding searchtext, UpdateSourceTrigger=PropertyChanged}" Width="200" Padding="5" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Button Content="Search" Command="{Binding SearchCommand}" Width="70" Padding="5" Background="#FF6B4736" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>

                            <DataGrid Grid.Row="1" 
                                      ItemsSource="{Binding ProductsView}" 
                                      SelectedItem="{Binding selecteditem, Mode=OneWayToSource}"
                                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                      Background="Transparent" BorderThickness="0" 
                                      RowBackground="White" AlternatingRowBackground="#FFF9F6F2"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" />
                                    <DataGridTemplateColumn Header="Image">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Image Source="{Binding ImagePath}" Width="50" Height="50" Stretch="UniformToFill"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*"/>

                                    <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" />
                                    <DataGridTextColumn Header="Brand" Binding="{Binding BrandName}" />

                                    <DataGridTextColumn Header="Type" Binding="{Binding Volume}" Width="60"/>
                                    <DataGridTextColumn Header="Price" Binding="{Binding Price}" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding IsActive}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="15">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Product Details" FontSize="20" FontWeight="Bold" Foreground="#FF4A2E1E" Margin="0,0,0,15"/>

                                <TextBlock Text="Product Name:" FontWeight="Bold" Foreground="#FF6F5547"/>
                                <TextBox Text="{Binding textboxitem.ProductName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" Padding="6"/>

                                <TextBlock Text="Volume (Type):" FontWeight="Bold" Foreground="#FF6F5547"/>
                                <TextBox Text="{Binding textboxitem.Volume, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" Padding="6"/>

                                <TextBlock Text="Price:" FontWeight="Bold" Foreground="#FF6F5547"/>
                                <TextBox Text="{Binding textboxitem.Price, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" Padding="6"/>

                                <TextBlock Text="Category:" FontWeight="Bold" Foreground="#FF6F5547"/>
                                <ComboBox ItemsSource="{Binding CategoriesList}" 
                                          DisplayMemberPath="CategoryName" 
                                          SelectedValuePath="CategoryId" 
                                          SelectedValue="{Binding textboxitem.CategoryId, UpdateSourceTrigger=PropertyChanged}" 
                                          Margin="0,5,0,10" Padding="6" Background="White"/>

                                <TextBlock Text="Brand:" FontWeight="Bold" Foreground="#FF6F5547"/>
                                <ComboBox ItemsSource="{Binding BrandsList}" 
                                          DisplayMemberPath="BrandName" 
                                          SelectedValuePath="BrandId" 
                                          SelectedValue="{Binding textboxitem.BrandId, UpdateSourceTrigger=PropertyChanged}" 
                                          Margin="0,5,0,10" Padding="6" Background="White"/>

                                <TextBlock Text="Image:" FontWeight="Bold" Foreground="#FF6F5547"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                                    <Button Content="Browse..." Command="{Binding ChooseImageCommand}" Width="75" Padding="5" Background="#FFB96D4A" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                    <TextBlock Text="{Binding textboxitem.ImagePath}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Width="140" Margin="10,0,0,0" Foreground="#FF6F5547"/>
                                </StackPanel>
                                <Image Source="{Binding textboxitem.ImagePath}" Height="100" Stretch="Uniform" Margin="0,0,0,20" HorizontalAlignment="Left"/>

                                <WrapPanel HorizontalAlignment="Center">
                                    <Button Content="Add New" Command="{Binding AddCommand}" Width="80" Margin="5" Padding="6" Background="#FF6B4736" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="Add Type" Command="{Binding AddTypeCommand}" Width="80" Margin="5" Padding="6" Background="#FFB96D4A" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="Update" Command="{Binding UpdateCommand}" Width="80" Margin="5" Padding="6" Background="#FF6B4736" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="Hide/Un" Command="{Binding DeleteCommand}" Width="80" Margin="5" Padding="6" Background="#FFB96D4A" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="Clear" Command="{Binding ClearCommand}" Width="80" Margin="5" Padding="6" Background="#FF8C7A6B" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>