<Page x:Class="CosmeticStoreManagement.Views.Admin.ManageStaffPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ManageStaffPage">
    <Page.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FFFCFAF7"/>
            <Setter Property="BorderBrush" Value="#FFD9C8BB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FF5A463C"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="OuterBorder"
                                Background="#FFFFFFFF"
                                BorderBrush="#FFD7C5B8"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="Indicator"
                                        Width="18"
                                        Height="18"
                                        CornerRadius="9"
                                        Background="#FFF4E7DB"
                                        BorderBrush="#FFD0B6A4"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <ContentPresenter/>
                                    <TextBlock x:Name="StatusHint"
                                               Text="Unchecked means Locked"
                                               FontSize="12"
                                               Foreground="#FF8A7466"
                                               FontWeight="Normal"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#FFC8DEC9"/>
                                <Setter TargetName="OuterBorder" Property="Background" Value="#FFF4FBF4"/>
                                <Setter TargetName="Indicator" Property="Background" Value="#FF6AA36E"/>
                                <Setter TargetName="Indicator" Property="BorderBrush" Value="#FF6AA36E"/>
                                <Setter TargetName="StatusHint" Property="Text" Value="Checked means Active"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#FFE0C7BC"/>
                                <Setter TargetName="OuterBorder" Property="Background" Value="#FFFEF4F1"/>
                                <Setter TargetName="Indicator" Property="Background" Value="#FFC96F60"/>
                                <Setter TargetName="Indicator" Property="BorderBrush" Value="#FFC96F60"/>
                                <Setter TargetName="StatusHint" Property="Text" Value="Unchecked means Locked"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFF2E4D8"/>
            <Setter Property="Foreground" Value="#FF5A4133"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderBrush" Value="#FFF2E4D8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10,10,0,0"
                                Padding="10,8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFF1E2D6"/>
                    <Setter Property="Foreground" Value="#FF4A2E1E"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CenteredElementStyle" TargetType="FrameworkElement">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#FF4A2E1E"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFF1E2D6"/>
                    <Setter Property="Foreground" Value="#FF4A2E1E"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF7EDE5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GridButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid Background="#FFF9F6F2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.35*"/>
            <ColumnDefinition Width="0.95*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="10,10,14,10"
                Padding="18"
                Background="White"
                BorderBrush="#FFE3D7CD"
                BorderThickness="1"
                CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Manage Staff"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#FF4A2E1E"/>
                    <TextBlock Text="Add, update, delete, and search staff accounts."
                               Margin="0,8,0,18"
                               FontSize="14"
                               Foreground="#FF7A6254"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,6,0,0"
                        Background="#FFFDFBFA"
                        BorderBrush="#FFEDDFD5"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="12"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="4,2,4,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Staff Accounts List"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#FF4A2E1E"/>
                                <TextBlock Text="Select one row to load data into the form."
                                           Margin="0,4,0,0"
                                           Foreground="#FF7A6254"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="#FFF2E4D8"
                                    CornerRadius="14"
                                    Padding="14,8"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding staffs.Count, StringFormat=Total: {0}}"
                                           FontWeight="Bold"
                                           Foreground="#FF6F4D3B"/>
                            </Border>
                        </Grid>

                        <Border Grid.Row="1"
                                Background="White"
                                CornerRadius="18"
                                BorderBrush="#FFF0E4DA"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <DataGrid ItemsSource="{Binding StaffView}"
                                      SelectedItem="{Binding selecteditem, Mode=OneWayToSource}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      AlternatingRowBackground="#FFF9F2EC"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                                      CellStyle="{StaticResource DataGridCellStyle}"
                                      RowStyle="{StaticResource DataGridRowStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding UserId}" Width="0.7*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredElementStyle}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="1.4*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredElementStyle}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="1.7*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredElementStyle}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="Status" Width="1.1*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock x:Name="StatusText"
                                                           Text="Active"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="#FF426247"/>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="False">
                                                        <Setter TargetName="StatusText" Property="Text" Value="Locked"/>
                                                        <Setter TargetName="StatusText" Property="Foreground" Value="#FF8A4C45"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Created Date" Binding="{Binding CreatedDate, StringFormat=dd/MM/yyyy}" Width="1.1*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredElementStyle}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="0,10,10,10"
                Padding="18"
                Background="#FFF4E8DE"
                BorderBrush="#FFE3D7CD"
                BorderThickness="1"
                CornerRadius="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Staff Form"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#FF4A2E1E"/>
                    <TextBlock Text="Only staff accounts are managed on this page."
                               Margin="0,8,0,18"
                               Foreground="#FF7A6254"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Username" FontWeight="Bold" Foreground="#FF5C463A"/>
                    <TextBox Margin="0,8,0,14"
                             Style="{StaticResource RoundedTextBoxStyle}"
                             Text="{Binding textboxitem.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Password" FontWeight="Bold" Foreground="#FF5C463A"/>
                    <TextBox Margin="0,8,0,14"
                             Style="{StaticResource RoundedTextBoxStyle}"
                             Text="{Binding textboxitem.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Full Name" FontWeight="Bold" Foreground="#FF5C463A"/>
                    <TextBox Margin="0,8,0,14"
                             Style="{StaticResource RoundedTextBoxStyle}"
                             Text="{Binding textboxitem.FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Status" FontWeight="Bold" Foreground="#FF5C463A"/>
                    <Border Margin="0,8,0,18"
                            Background="#FFF8EEE7"
                            BorderBrush="#FFE3CFC0"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Toggle account status"
                                       Foreground="#FF7A6254"
                                       Margin="0,0,0,10"/>
                            <CheckBox Content="Account is Active"
                                      Height="56"
                                      Style="{StaticResource StatusCheckBoxStyle}"
                                      IsChecked="{Binding textboxitem.Status, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFFF3F1"
                            BorderBrush="#FFF0CBC5"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,0,0,18">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding errormessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding errormessage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding errormessage}"
                                   Foreground="#FFD03B2A"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="ADD"
                                Margin="0,0,8,0"
                                Background="#FF8A5536"
                                Style="{StaticResource GridButtonStyle}"
                                Command="{Binding AddCommand}"/>
                        <Button Grid.Column="1"
                                Content="UPDATE"
                                Margin="8,0,8,0"
                                Background="#FFB0713D"
                                Style="{StaticResource GridButtonStyle}"
                                Command="{Binding UpdateCommand}"/>
                        <Button Grid.Column="2"
                                Content="CLEAR"
                                Margin="8,0,0,0"
                                Background="#FF6C7A87"
                                Style="{StaticResource GridButtonStyle}"
                                Command="{Binding ClearCommand}"/>
                    </Grid>

                    <TextBlock Text="Search" FontWeight="Bold" Foreground="#FF5C463A"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="96"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Margin="0,0,10,0"
                                 Style="{StaticResource RoundedTextBoxStyle}"
                                 Text="{Binding searchtext, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1"
                                Content="SEARCH"
                                Height="38"
                                Background="#FF5C7A57"
                                Style="{StaticResource RoundedButtonStyle}"
                                Command="{Binding SearchCommand}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
