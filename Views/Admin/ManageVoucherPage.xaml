<Page x:Class="CosmeticStoreManagement.Views.Admin.ManageVoucherPage"
      xmlns:vm="clr-namespace:CosmeticStoreManagement.ViewModels;assembly=CosmeticStoreManagement"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ManageVoucherPage" d:DesignHeight="674.702" d:DesignWidth="691.6">



    <Grid Background="#FFF9F6F2">

        <!-- ROW -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="Manage Voucher"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="20"
                   Foreground="#4A2E1E"/>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">

            <!-- 6 : 4 LAYOUT -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT : DATAGRID -->
            <Border Grid.Column="0"
                    Margin="20"
                    Padding="10"
                    Background="White"
                    CornerRadius="16">

                <DataGrid
                    ItemsSource="{Binding voucherView}"
                    SelectedItem="{Binding selecteditem}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    IsReadOnly="True"
                    RowHeight="32" SelectionChanged="DataGrid_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Code"
                                            Width="75"
                                            Binding="{Binding VoucherCode}"/>

                        <DataGridTextColumn Header="Type"
                                            Width="75"
                                            Binding="{Binding DiscountType}"/>

                        <DataGridTextColumn Header="Value"
                                            Width="90"
                                            Binding="{Binding DiscountValue}"/>

                        <DataGridTextColumn Header="Start Date"
                                            Width="170"
                                            Binding="{Binding StartDate}"/>

                        <DataGridTextColumn Header="End Date"
                                            Width="170"
                                            Binding="{Binding EndDate}"/>

                        <DataGridCheckBoxColumn Header="Active"
                                                Width="60"
                                                Binding="{Binding IsActive}"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Border>

            <!-- RIGHT : FORM -->
            <Border Grid.Column="1"
                    Margin="20"
                    Padding="20"
                    Background="#FFF5EBDD"
                    CornerRadius="16">

                <StackPanel>

                    <!-- Voucher Code -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Voucher Code" FontWeight="SemiBold"/>
                        <TextBox Height="30"
                                 Text="{Binding textboxitem.VoucherCode, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- Discount Type -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Discount Type" FontWeight="SemiBold"/>

                        <ComboBox Height="30"
                                  SelectedValue="{Binding textboxitem.DiscountType, Mode=TwoWay}"
                                  SelectedValuePath="Tag">

                            <ComboBoxItem Content="Percent (%)" Tag="PERCENT"/>
                            <ComboBoxItem Content="Fixed Amount" Tag="FIXED"/>

                        </ComboBox>

                    </StackPanel>

                    <!-- Discount Value -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Discount Value" FontWeight="SemiBold"/>
                        <TextBox Height="30"
                                 Text="{Binding textboxitem.DiscountValue, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- Start Date -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Start Date" FontWeight="SemiBold"/>
                        <DatePicker Height="30"
                                    SelectedDate="{Binding textboxitem.StartDate, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- End Date -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="End Date" FontWeight="SemiBold"/>
                        <DatePicker Height="30"
                                    SelectedDate="{Binding textboxitem.EndDate, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- Status -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Status" FontWeight="SemiBold"/>
                        <CheckBox Content="Active"
                                  IsChecked="{Binding textboxitem.IsActive, Mode=TwoWay}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Right">

                        <Button Content="Add"
            Width="90"
            Height="32"
            Margin="5"
            Background="#4A2E1E"
            Foreground="White"
            Command="{Binding AddCommand}"/>

                        <Button Content="Update"
            Width="90"
            Height="32"
            Margin="5"
            Background="#8B5E3C"
            Foreground="White"
            Command="{Binding UpdateCommand}"/>

                        <Button Content="Delete"
            Width="90"
            Height="32"
            Margin="5"
            Background="#C0392B"
            Foreground="White"
            Command="{Binding DeleteCommand}"/>

                        <Button Content="Clear"
            Width="90"
            Height="32"
            Margin="5"
            Background="#7F8C8D"
            Foreground="White"
            Command="{Binding ClearCommand}"/>

                    </StackPanel>
                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Page>