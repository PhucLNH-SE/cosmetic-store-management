<Page x:Class="CosmeticStoreManagement.Views.Admin.ManageVoucherPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ManageVoucherPage"
      Background="#FFF9F6F2"
      d:DesignHeight="675"
      d:DesignWidth="980">
    <Page.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FFFCFAF7"/>
            <Setter Property="BorderBrush" Value="#FFD9C8BB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="#FFFCFAF7"/>
            <Setter Property="BorderBrush" Value="#FFD9C8BB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="StatusCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FF5A463C"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="OuterBorder"
                                Background="#FFFFFFFF"
                                BorderBrush="#FFD7C5B8"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="Indicator"
                                        Width="18"
                                        Height="18"
                                        CornerRadius="9"
                                        Background="#FFF4E7DB"
                                        BorderBrush="#FFD0B6A4"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <ContentPresenter/>
                                    <TextBlock x:Name="StatusHint"
                                               Text="Unchecked means Inactive"
                                               FontSize="12"
                                               Foreground="#FF8A7466"
                                               FontWeight="Normal"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#FFC8DEC9"/>
                                <Setter TargetName="OuterBorder" Property="Background" Value="#FFF4FBF4"/>
                                <Setter TargetName="Indicator" Property="Background" Value="#FF6AA36E"/>
                                <Setter TargetName="Indicator" Property="BorderBrush" Value="#FF6AA36E"/>
                                <Setter TargetName="StatusHint" Property="Text" Value="Checked means Available to use"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#FFE0C7BC"/>
                                <Setter TargetName="OuterBorder" Property="Background" Value="#FFFEF4F1"/>
                                <Setter TargetName="Indicator" Property="Background" Value="#FFC96F60"/>
                                <Setter TargetName="Indicator" Property="BorderBrush" Value="#FFC96F60"/>
                                <Setter TargetName="StatusHint" Property="Text" Value="Unchecked means Inactive"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFF2E4D8"/>
            <Setter Property="Foreground" Value="#FF5A4133"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderBrush" Value="#FFF2E4D8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10,10,0,0"
                                Padding="10,8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFF1E2D6"/>
                    <Setter Property="Foreground" Value="#FF4A2E1E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#FF4A2E1E"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="46"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFF1E2D6"/>
                    <Setter Property="Foreground" Value="#FF4A2E1E"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF7EDE5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Background="#FFF9F6F2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.35*"/>
            <ColumnDefinition Width="0.95*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="10,10,14,10"
                Padding="18"
                Background="White"
                BorderBrush="#FFE3D7CD"
                BorderThickness="1"
                CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Manage Voucher"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#FF4A2E1E"/>
                    <TextBlock Text="Create voucher campaigns, control available quantity, and update discount timing."
                               Margin="0,8,0,18"
                               FontSize="14"
                               Foreground="#FF7A6254"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,6,0,0"
                        Background="#FFFDFBFA"
                        BorderBrush="#FFEDDFD5"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="4,2,4,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Voucher List"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#FF4A2E1E"/>
                                <TextBlock Text="Select one voucher row to load its information into the form."
                                           Margin="0,4,0,0"
                                           Foreground="#FF7A6254"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="#FFF2E4D8"
                                    CornerRadius="14"
                                    Padding="14,8"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding vouchers.Count, StringFormat=Total: {0}}"
                                           FontWeight="Bold"
                                           Foreground="#FF6F4D3B"/>
                            </Border>
                        </Grid>

                        <Border Grid.Row="1"
                                Background="White"
                                CornerRadius="18"
                                BorderBrush="#FFF0E4DA"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <DataGrid ItemsSource="{Binding voucherView}"
                                      SelectedItem="{Binding selecteditem}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      AlternatingRowBackground="#FFF9F2EC"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                                      CellStyle="{StaticResource DataGridCellStyle}"
                                      RowStyle="{StaticResource DataGridRowStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Code" Binding="{Binding VoucherCode}" Width="1.2*"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding DiscountType}" Width="0.9*"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding DiscountValue, StringFormat={}{0:N0}}" Width="0.9*"/>
                                    <DataGridTextColumn Header="Start Date" Binding="{Binding StartDate, StringFormat=dd/MM/yyyy}" Width="1.1*"/>
                                    <DataGridTextColumn Header="End Date" Binding="{Binding EndDate, StringFormat=dd/MM/yyyy}" Width="1.1*"/>
                                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="0.7*"/>
                                    <DataGridTemplateColumn Header="Status" Width="0.9*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock x:Name="VoucherStatusText"
                                                           Text="Active"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="#FF426247"/>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter TargetName="VoucherStatusText" Property="Text" Value="Inactive"/>
                                                        <Setter TargetName="VoucherStatusText" Property="Foreground" Value="#FF8A4C45"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="0,10,10,10"
                Padding="18"
                Background="#FFF4E8DE"
                BorderBrush="#FFE3D7CD"
                BorderThickness="1"
                CornerRadius="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Voucher Form"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#FF4A2E1E"/>
                    <TextBlock Text="Create a new voucher or update the selected row. Quantity controls how many times the voucher can still be applied."
                               Margin="0,8,0,18"
                               Foreground="#FF7A6254"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Voucher Code" FontWeight="Bold" Foreground="#FF5C463A"/>
                    <TextBox Margin="0,8,0,14"
                             Style="{StaticResource RoundedTextBoxStyle}"
                             Text="{Binding textboxitem.VoucherCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Discount Type" FontWeight="Bold" Foreground="#FF5C463A"/>
                    <ComboBox Margin="0,8,0,14"
                              Style="{StaticResource RoundedComboBoxStyle}"
                              SelectedValue="{Binding textboxitem.DiscountType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="Percent (%)" Tag="PERCENT"/>
                        <ComboBoxItem Content="Fixed Amount" Tag="FIXED"/>
                    </ComboBox>

                    <TextBlock Text="Discount Value" FontWeight="Bold" Foreground="#FF5C463A"/>
                    <TextBox Margin="0,8,0,14"
                             Style="{StaticResource RoundedTextBoxStyle}"
                             Text="{Binding textboxitem.DiscountValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Start Date" FontWeight="Bold" Foreground="#FF5C463A"/>
                            <DatePicker Margin="0,8,0,0"
                                        Height="38"
                                        SelectedDate="{Binding textboxitem.StartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="End Date" FontWeight="Bold" Foreground="#FF5C463A"/>
                            <DatePicker Margin="0,8,0,0"
                                        Height="38"
                                        SelectedDate="{Binding textboxitem.EndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Voucher Quantity" FontWeight="Bold" Foreground="#FF5C463A"/>
                    <TextBox Margin="0,8,0,18"
                             Style="{StaticResource RoundedTextBoxStyle}"
                             Text="{Binding textboxitem.Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Status" FontWeight="Bold" Foreground="#FF5C463A"/>
                    <Border Margin="0,8,0,18"
                            Background="#FFF8EEE7"
                            BorderBrush="#FFE3CFC0"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Toggle voucher availability"
                                       Foreground="#FF7A6254"
                                       Margin="0,0,0,10"/>
                            <CheckBox Content="Voucher is Active"
                                      Height="56"
                                      Style="{StaticResource StatusCheckBoxStyle}"
                                      IsChecked="{Binding textboxitem.IsActive, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="ADD"
                                Margin="0,0,8,0"
                                Background="#FF8A5536"
                                Style="{StaticResource RoundedButtonStyle}"
                                Command="{Binding AddCommand}"/>
                        <Button Grid.Column="1"
                                Content="UPDATE"
                                Margin="8,0,8,0"
                                Background="#FFB0713D"
                                Style="{StaticResource RoundedButtonStyle}"
                                Command="{Binding UpdateCommand}"/>
                        <Button Grid.Column="2"
                                Content="DELETE"
                                Margin="8,0,8,0"
                                Background="#FFC96F60"
                                Style="{StaticResource RoundedButtonStyle}"
                                Command="{Binding DeleteCommand}"/>
                        <Button Grid.Column="3"
                                Content="CLEAR"
                                Margin="8,0,0,0"
                                Background="#FF6C7A87"
                                Style="{StaticResource RoundedButtonStyle}"
                                Command="{Binding ClearCommand}"/>
                    </Grid>

                    <Border Background="#FFF8EEE7"
                            BorderBrush="#FFE3CFC0"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Quick Note"
                                       FontWeight="Bold"
                                       Foreground="#FF5C463A"/>
                            <TextBlock Text="Quantity is reduced by 1 every time staff successfully checks out with that voucher. Set the voucher inactive if you want to stop using it immediately."
                                       Margin="0,8,0,0"
                                       Foreground="#FF7A6254"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
