<Page x:Class="CosmeticStoreManagement.Views.Admin.ManageVoucherPage"
      xmlns:vm="clr-namespace:CosmeticStoreManagement.ViewModels;assembly=CosmeticStoreManagement"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ManageVoucherPage">
    

    <Grid Background="#FFF9F6F2">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="Manage Voucher"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="20"
                   Foreground="#4A2E1E"/>

        <!-- FORM -->
        <Border Grid.Row="1"
                Margin="20,0,20,10"
                Padding="20"
                Background="#FFF5EBDD"
                CornerRadius="16">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Voucher Code -->
                <StackPanel Margin="10">
                    <TextBlock Text="Voucher Code" FontWeight="SemiBold"/>
                    <TextBox Height="30"
                             Text="{Binding textboxitem.VoucherCode, Mode=TwoWay}"/>
                </StackPanel>

                <!-- Discount Type -->
                <StackPanel Grid.Column="1" Margin="10">
                    <TextBlock Text="Discount Type" FontWeight="SemiBold"/>

                    <ComboBox Height="30"
                              SelectedValue="{Binding textboxitem.DiscountType, Mode=TwoWay}"
                              SelectedValuePath="Tag">

                        <ComboBoxItem Content="Percent (%)" Tag="PERCENT"/>
                        <ComboBoxItem Content="Fixed Amount" Tag="FIXED"/>

                    </ComboBox>

                </StackPanel>

                <!-- Discount Value -->
                <StackPanel Grid.Column="2" Margin="10">
                    <TextBlock Text="Discount Value" FontWeight="SemiBold"/>
                    <TextBox Height="30"
                             Text="{Binding textboxitem.DiscountValue, Mode=TwoWay}"/>
                </StackPanel>

                <!-- Start Date -->
                <StackPanel Grid.Column="3" Margin="10">
                    <TextBlock Text="Start Date" FontWeight="SemiBold"/>
                    <DatePicker Height="30"
                                SelectedDate="{Binding textboxitem.StartDate, Mode=TwoWay}"/>
                </StackPanel>

                <!-- End Date -->
                <StackPanel Grid.Row="1" Margin="10">
                    <TextBlock Text="End Date" FontWeight="SemiBold"/>
                    <DatePicker Height="30"
                                SelectedDate="{Binding textboxitem.EndDate, Mode=TwoWay}"/>
                </StackPanel>

                <!-- Active Status -->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="10">
                    <TextBlock Text="Status" FontWeight="SemiBold"/>
                    <CheckBox Content="Active"
                              IsChecked="{Binding textboxitem.IsActive, Mode=TwoWay}"/>
                </StackPanel>

                <!-- BUTTONS -->
                <StackPanel Grid.Row="1"
            Grid.Column="2"
            Grid.ColumnSpan="2"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="10">

                    <Button Content="Add"
            Width="90"
            Height="32"
            Margin="5"
            Background="#4A2E1E"
            Foreground="White"
            Command="{Binding AddCommand}"/>

                    <Button Content="Update"
            Width="90"
            Height="32"
            Margin="5"
            Background="#8B5E3C"
            Foreground="White"
            Command="{Binding UpdateCommand}"/>

                    <Button Content="Delete"
            Width="90"
            Height="32"
            Margin="5"
            Background="#C0392B"
            Foreground="White"
            Command="{Binding DeleteCommand}"/>

                </StackPanel>
            </Grid>

        </Border>

        <!-- DATA GRID -->
        <Border Grid.Row="2"
                Margin="20"
                Padding="10"
                Background="White"
                CornerRadius="16">

            <DataGrid
                ItemsSource="{Binding voucherView}"
               SelectedItem="{Binding selecteditem}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                IsReadOnly="True"
                RowHeight="32">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Code"
                                        Width="*"
                                        Binding="{Binding VoucherCode}"/>

                    <DataGridTextColumn Header="Type"
                                        Width="120"
                                        Binding="{Binding DiscountType}"/>

                    <DataGridTextColumn Header="Value"
                                        Width="120"
                                        Binding="{Binding DiscountValue}"/>

                    <DataGridTextColumn Header="Start Date"
                                        Width="160"
                                        Binding="{Binding StartDate}"/>

                    <DataGridTextColumn Header="End Date"
                                        Width="160"
                                        Binding="{Binding EndDate}"/>

                    <DataGridCheckBoxColumn Header="Active"
                                            Width="80"
                                            Binding="{Binding IsActive}"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</Page>