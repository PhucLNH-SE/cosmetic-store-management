<Page x:Class="CosmeticStoreManagement.Views.Admin.ManageCategoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ManageCategoryPage"
      Background="#FFF7F3EE">
    <Page.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#FFFDFBF8"/>
            <Setter Property="BorderBrush" Value="#FFD9CCC1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FFF7F5F2"/>
            <Setter Property="BorderBrush" Value="#FFD2C3B7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TableHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFE8DDD2"/>
            <Setter Property="Foreground" Value="#FF4A3428"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderBrush" Value="#FFE8DDD2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="TableCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#FF33261F"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFE8DED4"/>
                    <Setter Property="Foreground" Value="#FF33261F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TableRowStyle" TargetType="DataGridRow">
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#FFF8F3ED"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FFFDFBF8"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF1E6DA"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFE8DED4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.75*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="1.15*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="14" CornerRadius="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Manage Category"
                                   FontSize="48"
                                   FontWeight="Bold"
                                   Foreground="#FF3D2A1F"/>
                        <TextBlock Grid.Row="1"
                                   Text="Add, update, and search category data."
                                   Margin="0,6,0,16"
                                   FontSize="16"
                                   Foreground="#FF7A695D"/>

                        <Border Grid.Row="2"
                                Background="#FFF4EFEA"
                                BorderBrush="#FFD9CCC1"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="10">
                            <DataGrid ItemsSource="{Binding CategoryView}"
                                      SelectedItem="{Binding selecteditem, Mode=OneWayToSource}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      RowHeaderWidth="0"
                                      GridLinesVisibility="None"
                                      HeadersVisibility="Column"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      ColumnHeaderStyle="{StaticResource TableHeaderStyle}"
                                      CellStyle="{StaticResource TableCellStyle}"
                                      RowStyle="{StaticResource TableRowStyle}"
                                      AlternationCount="2"
                                      HorizontalGridLinesBrush="#FFE7DCD2"
                                      VerticalGridLinesBrush="#FFE7DCD2">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding CategoryId}" Width="80"/>
                                    <DataGridTextColumn Header="Category Name" Binding="{Binding CategoryName}" Width="*"/>
                                    <DataGridCheckBoxColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource CardBorder}"
                        Padding="16"
                        Background="#FFF3E9E1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Category Form"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="#FF3D2A1F"/>
                            <TextBlock Text="Only active categories are managed on this page."
                                       Margin="0,4,0,10"
                                       Foreground="#FF7A695D"/>

                            <TextBlock Text="Category ID" Margin="0,8,0,4" FontWeight="Bold" Foreground="#FF4D3B30"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding textboxitem.CategoryId}"
                                     IsReadOnly="True"/>

                            <TextBlock Text="Category Name" Margin="0,10,0,4" FontWeight="Bold" Foreground="#FF4D3B30"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding textboxitem.CategoryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Status" Margin="0,12,0,4" FontWeight="Bold" Foreground="#FF4D3B30"/>
                            <Border Background="#FFE8EFE7"
                                    BorderBrush="#FFC7D5C6"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10">
                                <CheckBox Content="Category is Active"
                                          FontWeight="Bold"
                                          Foreground="#FF3E5E3D"
                                          IsChecked="{Binding textboxitem.Status, Mode=TwoWay}"/>
                            </Border>

                            <UniformGrid Rows="1" Columns="3" Margin="0,14,0,0">
                                <Button Content="ADD" Margin="0,0,8,0" Background="#FF8D5A37" Style="{StaticResource ActionButtonStyle}" Command="{Binding AddCommand}"/>
                                <Button Content="UPDATE" Margin="0,0,8,0" Background="#FFB37A3F" Style="{StaticResource ActionButtonStyle}" Command="{Binding UpdateCommand}"/>
                                <Button Content="CLEAR" Background="#FF6A7D91" Style="{StaticResource ActionButtonStyle}" Command="{Binding ClearCommand}"/>
                            </UniformGrid>

                            <TextBlock Text="Search" Margin="0,14,0,4" FontWeight="Bold" Foreground="#FF4D3B30"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="106"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         Text="{Binding searchtext, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Content="SEARCH"
                                        Background="#FF63865B"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding SearchCommand}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,10,0,0"
                Padding="10"
                CornerRadius="12"
                Background="#FFFFF8F3"
                BorderBrush="#FFE2D2C5"
                BorderThickness="1">
            <TextBlock Text="{Binding statusmessage}"
                       Foreground="#FF9A3B2D"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Page>
