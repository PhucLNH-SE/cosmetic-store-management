<Page x:Class="CosmeticStoreManagement.Views.Admin.ManageCategoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ManageCategoryPage">
    <Page.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#FFF7F1EA"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE5D8CD"/>
        <SolidColorBrush x:Key="HeaderBrush" Color="#FF6B4736"/>
        <SolidColorBrush x:Key="HeaderLightBrush" Color="#FFEEDCCD"/>
        <SolidColorBrush x:Key="InputBrush" Color="#FFFBF7F3"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF4E3629"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="#FFD8C8BB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.78"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CategoryGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="RowBackground" Value="#FFFFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#FFFAF5F0"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FFF0E5DC"/>
            <Setter Property="VerticalGridLinesBrush" Value="#FFF0E5DC"/>
        </Style>

        <Style x:Key="CategoryGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderBrush" Value="#FF7A5947"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style x:Key="CategoryGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF5EADF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource BgBrush}" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="1.25*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Style="{StaticResource CardBorderStyle}"
                Background="{StaticResource HeaderLightBrush}"
                Padding="16"
                Margin="0,0,0,12">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Manage Category"
                           FontSize="27"
                           FontWeight="Bold"
                           Foreground="#FF4A2E1E"/>
                <TextBlock Text="View Category List, Create, Update and Delete"
                           Margin="0,4,0,0"
                           FontSize="13"
                           Foreground="#FF6F5547"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Style="{StaticResource CardBorderStyle}"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Category List"
                           FontSize="17"
                           FontWeight="Bold"
                           Foreground="#FF4E3629"
                           Margin="4,0,0,10"/>

                <Border Grid.Row="1"
                        CornerRadius="12"
                        BorderBrush="#FFE5D8CD"
                        BorderThickness="1"
                        Background="White"
                        Padding="1"
                        ClipToBounds="True">
                    <DataGrid Style="{StaticResource CategoryGridStyle}"
                              ColumnHeaderStyle="{StaticResource CategoryGridHeaderStyle}"
                              RowStyle="{StaticResource CategoryGridRowStyle}"
                              ItemsSource="{Binding CategoryView}"
                              SelectedItem="{Binding selecteditem, Mode=OneWayToSource}"
                              AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding CategoryId}" Width="80"/>
                            <DataGridTextColumn Header="Category Name" Binding="{Binding CategoryName}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="2"
                Style="{StaticResource CardBorderStyle}"
                Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Category Form"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#FF4A2E1E"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Edit selected item or create new category"
                               Foreground="#FF7E6253"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Category ID" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding textboxitem.CategoryId}"
                             Style="{StaticResource RoundedTextBoxStyle}"
                             IsReadOnly="True"
                             Background="#FFF2EEE9"/>

                    <TextBlock Text="Category Name" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding textboxitem.CategoryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource RoundedTextBoxStyle}"/>

                    <CheckBox Content="Active"
                              Margin="0,14,0,0"
                              FontWeight="SemiBold"
                              Foreground="#FF4E3629"
                              IsChecked="{Binding textboxitem.Status, Mode=TwoWay}"/>

                    <UniformGrid Rows="2" Columns="2" Margin="0,18,0,0">
                        <Button Content="ADD"
                                Margin="0,0,8,8"
                                Background="#FF4F8A58"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding AddCommand}"/>
                        <Button Content="UPDATE"
                                Margin="0,0,0,8"
                                Background="#FF4E78B7"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding UpdateCommand}"/>
                        <Button Content="DELETE"
                                Margin="0,0,8,0"
                                Background="#FFB84E4E"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding DeleteCommand}"/>
                        <Button Content="CLEAR"
                                Background="#FF7B4D37"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding ClearCommand}"/>
                    </UniformGrid>

                    <TextBlock Text="Search"
                               Style="{StaticResource LabelStyle}"
                               Margin="0,16,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Style="{StaticResource RoundedTextBoxStyle}"
                                 Text="{Binding searchtext, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                Content="SEARCH"
                                Background="#FF7B4D37"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding SearchCommand}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Grid.ColumnSpan="3"
                Style="{StaticResource CardBorderStyle}"
                Padding="10"
                Margin="0,12,0,0"
                Background="#FFFFF8F3">
            <TextBlock Text="{Binding statusmessage}"
                       Foreground="#FF8F3A2D"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Page>
