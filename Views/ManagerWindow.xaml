<Window x:Class="CosmeticStoreManagement.Views.ManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:CosmeticStoreManagement.Helpers"
        mc:Ignorable="d"
        Title="Manager"
        Height="640"
        Width="1180"
        MinHeight="600"
        MinWidth="1040"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#FFF6F1EA">
    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFF7E7DB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2AF8E9DE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#FF5C3D2E" Padding="18">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Manager Dashboard"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="Welcome Manager"
           Foreground="#FFF8EDE3"
           FontSize="14"
           Margin="0,4,0,0"/>
                </StackPanel>

                <Button Content="Logout"
                        Width="110"
                        Height="38"
                        Background="#FFB96D4A"
                        Style="{StaticResource RoundedButtonStyle}"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right"
                        Click="Logout_Click"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FF6B4736"
                    CornerRadius="26"
                    Padding="18">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Admin Menu"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Select a feature to open its page."
                                   Margin="0,8,0,22"
                                   Foreground="#FFE7D7CA"
                                   TextWrapping="Wrap"/>

                        <Button Content="View statistics"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="ViewStatistics_Click"/>
                        <Button Content="Manage Brand"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="ManageBrand_Click"/>
                        <Button Content="Manage Category"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="ManageCategory_Click"/>
                        <Button Content="Manage Product"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="ManageProduct_Click"/>
                        <Button Content="Manage Voucher"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="ManageVoucher_Click"/>
                        <Button Content="Manage Import Product"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="ManageImportProduct_Click"/>
                        <Button Content="Manage Staff"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="ManageStaff_Click"/>
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom"
                            Margin="0,18,0,0"
                            Padding="16"
                            CornerRadius="18"
                            Background="#22FFFFFF">
                        <StackPanel>
                            <TextBlock Text="Manager role"
                                       Foreground="White"
                                       FontWeight="Bold"/>
                            <TextBlock Text="This sidebar is ready for CRUD pages following your MVVM page pattern."
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="#FFF2E6DD"/>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="26"
                    BorderBrush="#FFE3D7CD"
                    BorderThickness="1"
                    Padding="18">
                <Frame x:Name="frManager"
                       NavigationUIVisibility="Hidden"/>
            </Border>
        </Grid>
    </Grid>
</Window>
