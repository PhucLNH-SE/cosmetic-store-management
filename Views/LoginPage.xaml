<UserControl x:Class="CosmeticStoreManagement.Views.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="#F5F7FA">
        <Border Width="420"
                Padding="28"
                Background="White"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Admin Login"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Margin="0,0,0,20" />

                <TextBlock Text="Username" Margin="0,0,0,6" />
                <TextBox Height="36"
                         Padding="10,6"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Password" Margin="0,14,0,6" />
                <PasswordBox x:Name="PasswordInput"
                             Height="36"
                             Padding="10,6" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Margin="0,12,0,0"
                           Foreground="#D32F2F"
                           TextWrapping="Wrap" />

                <Button Content="Sign In"
                        Height="40"
                        Margin="0,20,0,0"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=PasswordInput}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
