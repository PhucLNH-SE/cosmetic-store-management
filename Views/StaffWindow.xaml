<Window x:Class="CosmeticStoreManagement.Views.StaffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:CosmeticStoreManagement.Helpers"
        mc:Ignorable="d"
        Title="Staff"
        Height="700"
        Width="1200"
        MinHeight="600"
        MinWidth="1000"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#FFF1F6F1">
    <Window.Resources>
        <!-- Button Style for Menu -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF4A7C5E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active Menu Button Style -->
        <Style x:Key="ActiveMenuButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#FF5D9B68"/>
        </Style>

        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR MENU -->
        <Border Grid.Column="0" Background="#FF3E6B48">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo/Title -->
                <Border Grid.Row="0" Padding="20,24">
                    <StackPanel>
                        <TextBlock Text="🧴 Cosmetic Store"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Staff Panel"
                                   FontSize="12"
                                   Foreground="#FFB8D4BE"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Menu Items -->
                <StackPanel Grid.Row="1" Margin="0,20,0,0">
                    <Button Content="🛒  Products" 
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Products_Click"/>
                    <Button Content="🛍️  Cart" 
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Cart_Click"/>
                    <Button Content="👥  Customer" 
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Customer_Click"/>
                    <Button Content="🎟️  Voucher" 
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Voucher_Click"/>
                    <Button Content="💳  Payment" 
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Payment_Click"/>
                    <Button Content="📦  Order" 
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Order_Click"/>
                </StackPanel>

                <!-- Logout -->
                <Border Grid.Row="2" Padding="16,16">
                    <Button Content="Logout"
                            Style="{StaticResource RoundedButtonStyle}"
                            Background="#FF5D9B68"
                            Click="Logout_Click"/>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#FF3E6B48" Padding="24,16">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Staff Dashboard"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding Source={x:Static helpers:UserSession.CurrentUser}, Path=FullName, StringFormat='Welcome, {0}'}"
                                   Foreground="#FFE8F3E8"
                                   FontSize="13"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Frame for Pages -->
            <Frame x:Name="mainFrame" Grid.Row="1" 
                   NavigationUIVisibility="Hidden"
                   Background="#FFF1F6F1"/>
        </Grid>
    </Grid>
</Window>
