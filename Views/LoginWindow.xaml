<Window x:Class="CosmeticStoreManagement.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Cosmetic Store Login"
        Height="520"
        Width="920"
        MinHeight="520"
        MinWidth="860"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#FFF7F1EA">
    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#FF9A563A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF7E432A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#FFFBF7F3"/>
            <Setter Property="BorderBrush" Value="#FFD9C4B2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#FFFBF7F3"/>
            <Setter Property="BorderBrush" Value="#FFD9C4B2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*"/>
            <ColumnDefinition Width="0.9*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFF2D8C2" Offset="0"/>
                    <GradientStop Color="#FFE9B28A" Offset="0.55"/>
                    <GradientStop Color="#FFD1865B" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel Margin="56" VerticalAlignment="Center">
                <TextBlock Text="Cosmetic Store"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="#FF4A2D20"/>
                <TextBlock Text="Point of sale and management"
                           Margin="0,14,0,0"
                           FontSize="18"
                           Foreground="#FF6C4A37"/>
                <TextBlock Text="Sign in to access the manager or staff workspace."
                           Margin="0,18,0,0"
                           FontSize="15"
                           Foreground="#FF6A5144"
                           TextWrapping="Wrap"/>

                <Border Margin="0,34,0,0"
                        Padding="20"
                        Width="320"
                        CornerRadius="22"
                        Background="#33FFFFFF">
                    <StackPanel>
                        <TextBlock Text="Manager"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#FF4A2D20"/>
                        <TextBlock Text="Manage products, staff, vouchers, imports, and reports."
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="#FF5B4439"/>
                        <Separator Margin="0,14,0,14"/>
                        <TextBlock Text="Staff"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#FF4A2D20"/>
                        <TextBlock Text="Create carts, orders, and support customers at the counter."
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="#FF5B4439"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Margin="34">
            <Border Padding="34"
                    Background="White"
                    CornerRadius="24"
                    BorderBrush="#FFE3D4C8"
                    BorderThickness="1"
                    MaxWidth="390"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Login"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#FF3F2A20"/>
                    <TextBlock Text="Use your staff or manager account"
                               Margin="0,8,0,26"
                               FontSize="14"
                               Foreground="#FF8D7364"/>

                    <TextBlock Text="Username"
                               FontWeight="Bold"
                               Foreground="#FF5A463C"/>
                    <TextBox Margin="0,8,0,18"
                             Style="{StaticResource RoundedTextBoxStyle}"
                             Text="{Binding username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Password"
                               FontWeight="Bold"
                               Foreground="#FF5A463C"/>
                    <PasswordBox x:Name="txtPassword"
                                 Margin="0,8,0,14"
                                 Style="{StaticResource RoundedPasswordStyle}"/>

                    <Border Background="#FFFFF1F0"
                            BorderBrush="#FFF0C8C3"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,0,0,18">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding errormessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding errormessage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding errormessage}"
                                   Foreground="#FFD03B2A"
                                   MinHeight="20"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Button Content="LOGIN"
                            Height="44"
                            IsDefault="True"
                            Style="{StaticResource RoundedButtonStyle}"
                            Command="{Binding LoginCommand}"
                            CommandParameter="{Binding ElementName=txtPassword}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
