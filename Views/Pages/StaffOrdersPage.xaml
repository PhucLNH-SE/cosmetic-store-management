<Page x:Class="CosmeticStoreManagement.Views.Pages.StaffOrdersPage"
      x:Name="OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="StaffOrdersPage"
      Background="#FFF1F6F1"
      d:DesignHeight="650"
      d:DesignWidth="1100">
    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF244330"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF6F8273"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="170"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD9E4DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinWidth" Value="260"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD9E4DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF3E6B48"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF4A7C5E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFE8F2EA"/>
            <Setter Property="Foreground" Value="#FF3E6B48"/>
        </Style>

        <Style x:Key="WarningButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFDF0DD"/>
            <Setter Property="Foreground" Value="#FFB97925"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFBE9E7"/>
            <Setter Property="Foreground" Value="#FFD55342"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="False"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="58"/>
            <Setter Property="AlternatingRowBackground" Value="#FFF8FBF9"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF5F7462"/>
            <Setter Property="Background" Value="#FFF4F8F5"/>
            <Setter Property="BorderBrush" Value="#00000000"/>
            <Setter Property="Padding" Value="10,12"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Margin="0,0,0,18">
            <Border.Effect>
                <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Order Management"
                           Style="{StaticResource SectionTitleStyle}"/>
                <TextBlock Text="Review the orders created by the current staff account, inspect details, and update pending orders when needed."
                           Margin="0,6,0,18"
                           Foreground="#FF6B7F70"
                           TextWrapping="Wrap"/>

                <WrapPanel>
                    <StackPanel Margin="0,0,14,12">
                        <TextBlock Text="Status" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding StatusOptions}"
                                  SelectedItem="{Binding SelectedStatus}"
                                  Style="{StaticResource FilterComboBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,14,12">
                        <TextBlock Text="Search" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchTextBoxStyle}"/>
                    </StackPanel>

                    <Button Content="Clear filters"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Margin="0,0,10,12"
                            Command="{Binding ClearFiltersCommand}"/>

                    <Button Content="Refresh"
                            Style="{StaticResource PrimaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,12"
                            Command="{Binding RefreshCommand}"/>
                </WrapPanel>

                <WrapPanel Margin="0,4,0,0">
                    <Border Background="#FFE9F3EB" CornerRadius="12" Padding="12,6" Margin="0,0,10,0">
                        <TextBlock Text="{Binding TotalOrders, StringFormat='Total: {0}'}"
                                   Foreground="#FF3E6B48"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#FFFDF0DD" CornerRadius="12" Padding="12,6" Margin="0,0,10,0">
                        <TextBlock Text="{Binding PendingOrders, StringFormat='Pending: {0}'}"
                                   Foreground="#FFB97925"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#FFEAF4ED" CornerRadius="12" Padding="12,6" Margin="0,0,10,0">
                        <TextBlock Text="{Binding CompletedOrders, StringFormat='Completed: {0}'}"
                                   Foreground="#FF3E6B48"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#FFFBE9E7" CornerRadius="12" Padding="12,6">
                        <TextBlock Text="{Binding CancelledOrders, StringFormat='Cancelled: {0}'}"
                                   Foreground="#FFD55342"
                                   FontWeight="SemiBold"/>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <Border.Effect>
                    <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="2"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="20,20,20,12">
                        <StackPanel>
                            <TextBlock Text="Orders"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Only orders created by the current staff account are shown here."
                                       Margin="0,4,0,0"
                                       Foreground="#FF6B7F70"/>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding OrdersView}"
                              SelectedItem="{Binding SelectedOrder}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Order"
                                                Binding="{Binding OrderId, StringFormat='#{0}'}"
                                                Width="75"/>
                            <DataGridTextColumn Header="Date"
                                                Binding="{Binding OrderDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                                Width="145"/>
                            <DataGridTextColumn Header="Customer"
                                                Binding="{Binding CustomerName}"
                                                Width="1.4*"/>
                            <DataGridTextColumn Header="Phone"
                                                Binding="{Binding CustomerPhone}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Items"
                                                Binding="{Binding ItemCount}"
                                                Width="70"/>
                            <DataGridTextColumn Header="Final Amount"
                                                Binding="{Binding FinalAmount, StringFormat='{}{0:N0} VND'}"
                                                Width="130"/>
                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"
                                                Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="18"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Border.Effect>
                    <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="2"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Order Details"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="{Binding SelectedOrderSummary}"
                                   Margin="0,6,0,14"
                                   Foreground="#FF6B7F70"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="#FFF8FBF9"
                                    CornerRadius="14"
                                    Padding="28"
                                    Visibility="{Binding HasSelectedOrder, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="No order selected"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#FF3E6B48"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Choose an order from the table to view its detail lines."
                                               Margin="0,8,0,0"
                                               Foreground="#FF6B7F70"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Visibility="{Binding HasSelectedOrder, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Border Background="#FFF4F8F5"
                                        CornerRadius="14"
                                        Padding="16"
                                        Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Customer" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="{Binding SelectedOrder.CustomerName}" FontWeight="Bold" Foreground="#FF244330"/>
                                            <TextBlock Text="{Binding SelectedOrder.CustomerPhone}" Margin="0,4,0,0" Foreground="#FF6B7F70"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Order Info" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="{Binding SelectedOrder.Status, StringFormat='Status: {0}'}" FontWeight="Bold" Foreground="#FF244330"/>
                                            <TextBlock Text="{Binding SelectedOrder.VoucherCode, StringFormat='Voucher: {0}'}" Margin="0,4,0,0" Foreground="#FF6B7F70"/>
                                            <TextBlock Text="{Binding SelectedOrder.Rating, StringFormat='Rating: {0}'}" Margin="0,4,0,0" Foreground="#FF6B7F70"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <ItemsControl ItemsSource="{Binding SelectedOrderLines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FFF9FCFA"
                                                    CornerRadius="14"
                                                    BorderBrush="#FFE1ECE3"
                                                    BorderThickness="1"
                                                    Padding="14"
                                                    Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="58"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                            Width="46"
                                                            Height="46"
                                                            CornerRadius="10"
                                                            Background="#FFF0F4F0">
                                                        <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                                               Stretch="UniformToFill">
                                                            <Image.Clip>
                                                                <RectangleGeometry Rect="0,0,46,46" RadiusX="10" RadiusY="10"/>
                                                            </Image.Clip>
                                                        </Image>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Margin="8,0,12,0">
                                                        <TextBlock Text="{Binding ProductName}"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FF244330"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Volume, StringFormat='Variant: {0}'}"
                                                                   Margin="0,4,0,0"
                                                                   Foreground="#FF6B7F70"/>
                                                        <TextBlock Text="{Binding Quantity, StringFormat='Quantity: {0}'}"
                                                                   Margin="0,4,0,0"
                                                                   Foreground="#FF8A988C"
                                                                   FontSize="12"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding UnitPrice, StringFormat='{}{0:N0} VND'}"
                                                                   HorizontalAlignment="Right"
                                                                   Foreground="#FF3E6B48"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Subtotal, StringFormat='Line total: {0:N0} VND'}"
                                                                   Margin="0,6,0,0"
                                                                   HorizontalAlignment="Right"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FF244330"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Background="#FFF5F8F5"
                                        CornerRadius="14"
                                        Padding="16"
                                        Margin="0,4,0,0">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="Original total"
                                                       Foreground="#FF627365"/>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding SelectedOrder.TotalAmount, StringFormat='{}{0:N0} VND'}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FF244330"/>
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="Final total"
                                                       FontWeight="Bold"
                                                       Foreground="#FF244330"/>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding SelectedOrder.FinalAmount, StringFormat='{}{0:N0} VND'}"
                                                       FontWeight="Bold"
                                                       Foreground="#FF3E6B48"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding SelectedOrder.Comment, StringFormat='Note: {0}'}"
                                                   Foreground="#FF6B7F70"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <WrapPanel Grid.Row="2"
                               Margin="0,18,0,0"
                               HorizontalAlignment="Right">
                        <Button Content="Mark Completed"
                                Style="{StaticResource WarningButtonStyle}"
                                Margin="0,0,10,0"
                                Command="{Binding CompleteOrderCommand}"/>
                        <Button Content="Cancel Order"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding CancelOrderCommand}"/>
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
