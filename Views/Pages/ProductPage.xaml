<Page x:Class="CosmeticStoreManagement.Views.Pages.ProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:vm="clr-namespace:CosmeticStoreManagement.ViewModels"
      mc:Ignorable="d"
      Title="Products"
      d:DesignHeight="650" 
      d:DesignWidth="1100"
      Background="#FFF1F6F1">
    <Page.Resources>
        <!-- Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        
        <!-- ComboBox ToggleButton Style -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="32"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="10" Background="White" BorderBrush="#FFE0E0E0" BorderThickness="1"/>
                <Path x:Name="Arrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#FF7B8A7D"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#FF3E6B48"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Arrow" Property="RenderTransform">
                        <Setter.Value>
                            <RotateTransform Angle="180" CenterX="4" CenterY="2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        
        <!-- ComboBox TextBox Style -->
        <ControlTemplate x:Key="ComboBoxTextBox" TargetType="TextBox">
            <Border x:Name="PART_ContentHost" Focusable="False" Background="Transparent"/>
        </ControlTemplate>
        
        <!-- ComboBox Item Style -->
        <Style x:Key="ComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#FF5F7B67"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFE7F3E8"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF3E6B48"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ComboBox Style -->
        <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#FF5F7B67"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Template="{StaticResource ComboBoxToggleButton}" Focusable="False" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="14,10,32,10" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="White" CornerRadius="10" Margin="0,6,0,0" BorderBrush="#FFE0E0E0" BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="3" Opacity="0.15"/>
                                        </Border.Effect>
                                        <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ComboBoxItemStyle}"/>
        </Style>
        
        <!-- TextBox Style -->
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinWidth" Value="280"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF3E6B48"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF3E6B48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF3E6B48"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF4A7C5E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFE7F3E8"/>
            <Setter Property="Foreground" Value="#FF3E6B48"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFD4E9D7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Add Button Style -->
        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF3E6B48"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF4A7C5E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FILTER BAR -->
        <Border Grid.Row="0" Background="White" CornerRadius="16" Padding="20" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Thương hiệu" FontSize="12" FontWeight="Medium" Foreground="#FF7B8A7D" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Brands}" SelectedItem="{Binding SelectedBrand}" DisplayMemberPath="BrandName" Style="{StaticResource FilterComboBoxStyle}"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Danh mục" FontSize="12" FontWeight="Medium" Foreground="#FF7B8A7D" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="CategoryName" Style="{StaticResource FilterComboBoxStyle}"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Sắp xếp" FontSize="12" FontWeight="Medium" Foreground="#FF7B8A7D" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}" Style="{StaticResource FilterComboBoxStyle}" MinWidth="150"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,0" VerticalAlignment="Bottom">
                    <TextBlock Text="Tìm kiếm" FontSize="12" FontWeight="Medium" Foreground="#FF7B8A7D" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchTextBoxStyle}"/>
                </StackPanel>
                <Button Content="🔄 Xóa lọc" Style="{StaticResource SecondaryButtonStyle}" VerticalAlignment="Bottom" Height="40" Click="ClearFilters_Click"/>
            </StackPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PRODUCT LIST -->
            <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="0" Margin="0,0,16,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <DataGrid ItemsSource="{Binding ProductVariantsView}"
          SelectedItem="{Binding SelectedProductVariant}"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          IsReadOnly="True"
          HeadersVisibility="Column"
          GridLinesVisibility="None"
          BorderThickness="0"
          RowHeight="65"
          Background="Transparent"
          RowBackground="White"
          AlternatingRowBackground="#FFFAFCFB"
          SelectionMode="Single"
          SelectionUnit="FullRow">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand"/>

                            <Style.Triggers>

                                <!-- Hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFF2F7F3"/>
                                </Trigger>

                                <!-- Selected -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FFE7F3E8"/>
                                </Trigger>

                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <!-- Image Column -->
                        <DataGridTemplateColumn Header="" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="44" Height="44" CornerRadius="10" Background="#FFF8F8F8" Margin="4">
                                        <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill">
                                            <Image.Clip>
                                                <RectangleGeometry Rect="0,0,44,44" RadiusX="10" RadiusY="10"/>
                                            </Image.Clip>
                                        </Image>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding Product.ProductName}" Width="*">
                            <DataGridColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#FF5F7B67"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="10,12"/>
                                    <Setter Property="Height" Value="50"/>
                                </Style>
                            </DataGridColumn.HeaderStyle>
                            <DataGridColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#FFE7F3E8"/>
                                            <Setter Property="Foreground" Value="#FF244330"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Dung tích" Binding="{Binding Volume}" Width="80">
                            <DataGridColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#FF5F7B67"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="10,12"/>
                                    <Setter Property="Height" Value="50"/>
                                </Style>
                            </DataGridColumn.HeaderStyle>
                            <DataGridColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#FFE7F3E8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat='{}{0:N0}đ'}" Width="100">
                            <DataGridColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#FF5F7B67"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="10,12"/>
                                    <Setter Property="Height" Value="50"/>
                                </Style>
                            </DataGridColumn.HeaderStyle>
                            <DataGridColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#FF3E6B48"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#FFE7F3E8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Kho" Binding="{Binding StockQuantity}" Width="55">
                            <DataGridColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#FF5F7B67"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="10,12"/>
                                    <Setter Property="Height" Value="50"/>
                                </Style>
                            </DataGridColumn.HeaderStyle>
                            <DataGridColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#FFE7F3E8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridColumn.CellStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- SPLITTER -->
            <GridSplitter Grid.Column="1" Width="8" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- PRODUCT DETAIL PANEL -->
            <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="24">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="CHI TIẾT SẢN PHẨM" FontSize="15" FontWeight="Bold" Foreground="#FF5F7B67" Margin="0,0,0,20"/>
                        
                        <!-- No selection message -->
                        <Border Background="#FFF9FCFB" CornerRadius="12" Padding="30" Margin="0,30,0,0"
                                Visibility="{Binding HasSelectedProduct, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🛒" FontSize="48" HorizontalAlignment="Center"/>
                                <TextBlock Text="Chọn một sản phẩm từ danh sách" Foreground="#FF7B8A7D" FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                <TextBlock Text="để xem chi tiết" Foreground="#FF7B8A7D" FontSize="14" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Product Details -->
                        <StackPanel Visibility="{Binding HasSelectedProduct, Converter={StaticResource BoolToVisibilityConverter}}">
                            <!-- Product Image -->
                            <Border Background="#FFF8F8F8" CornerRadius="16" Height="200" Margin="0,0,0,20">
                                <Image Source="{Binding SelectedProductImage, Converter={StaticResource ImagePathConverter}}" Stretch="Uniform" Margin="15">
                                    <Image.Clip>
                                        <RectangleGeometry Rect="0,0,170,170" RadiusX="10" RadiusY="10"/>
                                    </Image.Clip>
                                </Image>
                            </Border>
                            
                            <TextBlock Text="{Binding SelectedProductName}" FontSize="20" FontWeight="Bold" Foreground="#FF244330" TextWrapping="Wrap" Margin="0,0,0,14"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#FFE7F3E8" CornerRadius="10" Padding="14,6" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding SelectedProductBrand}" FontSize="13" FontWeight="Medium" Foreground="#FF3E6B48"/>
                                </Border>
                                <Border Background="#FFF3E8F8" CornerRadius="10" Padding="14,6">
                                    <TextBlock Text="{Binding SelectedProductCategory}" FontSize="13" FontWeight="Medium" Foreground="#FF8B5FA3"/>
                                </Border>
                            </StackPanel>
                            
                            <TextBlock Text="Mô tả:" FontWeight="SemiBold" Foreground="#FF5F7B67" Margin="0,10,0,6"/>
                            <TextBlock Text="{Binding SelectedProductDescription}" Foreground="#FF6B7B6B" TextWrapping="Wrap" Margin="0,0,0,20" MinHeight="50" LineHeight="22"/>
                            
                            <Border Height="1" Background="#FFEEF2F0" Margin="0,0,0,16"/>
                            
                            <TextBlock Text="Các phiên bản có sẵn:" FontWeight="SemiBold" Foreground="#FF5F7B67" Margin="0,0,0,12"/>
                            
                            <!-- Variants List -->
                            <ItemsControl ItemsSource="{Binding SelectedProductVariants}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFFAFCFB" CornerRadius="12" Padding="14" Margin="0,0,0,10" BorderBrush="#FFE8F3E8" BorderThickness="1">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1" Opacity="0.05"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Variant Image -->
                                                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="#FFF5F5F5" Margin="0,0,12,0">
                                                    <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill">
                                                        <Image.Clip>
                                                            <RectangleGeometry Rect="0,0,42,42" RadiusX="10" RadiusY="10"/>
                                                        </Image.Clip>
                                                    </Image>
                                                </Border>
                                                
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Volume}" FontWeight="SemiBold" FontSize="14" Foreground="#FF244330"/>
                                                    <TextBlock Text="{Binding StockQuantity, StringFormat='Còn {0} sản phẩm'}" FontSize="12" Foreground="#FF8B9A8B"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat='{}{0:N0}đ'}" FontWeight="Bold" FontSize="15" Foreground="#FF3E6B48" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                                <Button Grid.Column="3" Content="+ Thêm" Style="{StaticResource AddButtonStyle}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
