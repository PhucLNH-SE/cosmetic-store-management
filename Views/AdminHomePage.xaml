<UserControl x:Class="CosmeticStoreManagement.Views.AdminHomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#E7EAED">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2F6659">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="220" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="84" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="18,20,18,10">
                    <Border Background="#244D43" CornerRadius="12" Height="130" Padding="10">
                        <Image Source="D:\PRN121\hinhPRN\product_1.png" Stretch="Uniform" />
                    </Border>
                    <TextBlock Text="Cosmetic Store"
                               Foreground="#F2F5F4"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Margin="0,14,0,0" />
                    <TextBlock Text="Admin Dashboard"
                               Foreground="#DDE7E3"
                               FontSize="14"
                               Margin="0,2,0,0" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8,0">
                    <ItemsControl ItemsSource="{Binding ModuleItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectModuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,4"
                                        Padding="12,10"
                                        BorderThickness="0"
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#2F6659" />
                                            <Setter Property="Foreground" Value="#EAF2EF" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="#C1D4CC" />
                                                    <Setter Property="Foreground" Value="#1E4037" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="16"
                                                   VerticalAlignment="Center" />

                                        <Border Grid.Column="1"
                                                Background="#F0F5F2"
                                                CornerRadius="10"
                                                Padding="8,2"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Count}"
                                                       Foreground="#1E4037"
                                                       FontWeight="Bold" />
                                        </Border>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Row="2"
                        Margin="14"
                        Content="Sign Out"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Height="52"
                        Background="#E5EFEA"
                        Foreground="#21463B"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding LogoutCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="18,14,18,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="94" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#F2F4F3" CornerRadius="8" Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding SelectedModuleItem.Title, TargetNullValue=Menu}"
                                   FontSize="38"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding HeaderDateText}"
                                   FontSize="16"
                                   Foreground="#5B6A65"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding WelcomeText}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,18,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding RoleText}"
                                   FontSize="16"
                                   Foreground="#4D5D57"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.18*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#F8F9F8" CornerRadius="8" Padding="14,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="56" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding SortOptions}"
                                      SelectedItem="{Binding SelectedSortOption}"
                                      Height="36"
                                      Margin="0,0,10,0" />

                            <TextBox Grid.Column="1"
                                     Height="36"
                                     Padding="12,6"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                            <Button Grid.Column="2"
                                    Content="Refresh"
                                    Height="36"
                                    Width="95"
                                    Margin="10,0,0,0"
                                    BorderThickness="0"
                                    Background="#2F6659"
                                    Foreground="White"
                                    Command="{Binding RefreshCatalogCommand}" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="{Binding FilteredProductCount, StringFormat=Products: {0}}"
                                       FontSize="14"
                                       Foreground="#5A6A64"
                                       Margin="4,0,0,8" />

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding ProductView}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="220"
                                                    Margin="6"
                                                    Padding="10"
                                                    Background="White"
                                                    CornerRadius="8"
                                                    BorderBrush="#E1E5E3"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="150" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Border Grid.Row="0" Background="#F4F7F5" CornerRadius="6">
                                                        <Image Source="{Binding ImageAbsolutePath}" Stretch="Uniform" Margin="6" />
                                                    </Border>

                                                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                                        <TextBlock Text="{Binding ProductName}"
                                                                   FontSize="17"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Subtitle}"
                                                                   FontSize="12"
                                                                   Margin="0,4,0,0"
                                                                   Foreground="#5B6A65"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Price, StringFormat={}{0:N0} VND}"
                                                                   FontSize="24"
                                                                   Margin="0,8,0,0"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding StockText}"
                                                                   FontSize="12"
                                                                   Foreground="#6A7973"
                                                                   Margin="0,4,0,0" />
                                                        <Button Content="THEM"
                                                                Margin="0,10,0,0"
                                                                Height="34"
                                                                BorderThickness="0"
                                                                Background="#2F6659"
                                                                Foreground="White"
                                                                FontWeight="SemiBold"
                                                                Command="{Binding DataContext.AddToOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="#FAFBFA" CornerRadius="8" Margin="14,0,0,0" Padding="14,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="106" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="220" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#2F6659" CornerRadius="14" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="New Order"
                                               Foreground="White"
                                               FontSize="32"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding HeaderDateText}"
                                               Foreground="#DAE8E3"
                                               FontSize="14"
                                               Margin="0,4,0,0" />
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding TotalQuantity, StringFormat=Items: {0}}"
                                           Foreground="White"
                                           FontSize="18"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="0,12,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="36" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Product" FontWeight="SemiBold" Foreground="#566660" />
                                <TextBlock Grid.Column="1" Text="Qty" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#566660" />
                                <TextBlock Grid.Column="2" Text="Amount" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="#566660" />
                            </Grid>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding OrderItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,5"
                                                    Padding="0,6"
                                                    BorderBrush="#D7DDDA"
                                                    BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="56" />
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="36" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="14"
                                                               TextWrapping="Wrap"
                                                               Margin="2,0,6,0" />

                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Quantity}"
                                                               FontSize="14"
                                                               HorizontalAlignment="Center" />

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding LineTotal, StringFormat={}{0:N0} VND}"
                                                               FontSize="14"
                                                               HorizontalAlignment="Right" />

                                                    <Button Grid.Column="3"
                                                            Content="x"
                                                            Width="26"
                                                            Height="24"
                                                            Margin="8,0,0,0"
                                                            BorderThickness="0"
                                                            Background="#F5DFE0"
                                                            Foreground="#A62A2E"
                                                            Command="{Binding DataContext.RemoveOrderItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Total"
                                           FontSize="30"
                                           FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TotalAmount, StringFormat={}{0:N0} VND}"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="#2F6659" />
                            </Grid>

                            <TextBlock Text="Customer phone" FontSize="13" Foreground="#5A6A65" />
                            <TextBox Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34"
                                     Padding="8,4" />

                            <TextBlock Text="Customer name" FontSize="13" Foreground="#5A6A65" Margin="0,8,0,0" />
                            <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34"
                                     Padding="8,4" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="Clear"
                                        Height="40"
                                        Margin="0,0,8,0"
                                        BorderThickness="0"
                                        Background="#E4E8E6"
                                        Foreground="#294E43"
                                        FontWeight="SemiBold"
                                        Command="{Binding ClearOrderCommand}" />

                                <Button Grid.Column="1"
                                        Content="Create Order"
                                        Height="40"
                                        Margin="8,0,0,0"
                                        BorderThickness="0"
                                        Background="#2F6659"
                                        Foreground="White"
                                        FontWeight="SemiBold"
                                        Command="{Binding CheckoutCommand}" />
                            </Grid>

                            <TextBlock Text="{Binding StatusMessage}"
                                       Margin="0,8,0,0"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Foreground="{Binding StatusBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

